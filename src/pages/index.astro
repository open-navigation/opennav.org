---
import BaseLayout from '@layouts/BaseLayout.astro';
import HeroBalloon from '@components/HeroBalloon.astro';
import HeroVideo from '@components/HeroVideo.astro';
import SponsorsShowcase from '@components/SponsorsShowcase.astro';
import LowPolyBackground from '@components/LowPolyBackground.astro';

const features = [
  {
    title: 'Additional Modern Capabilities',
    description: 'Allows development of state-of-the-art planning, localization, control, behavior, and perception technologies - and tools.',
    icon: 'sparkles',
  },
  {
    title: 'Reduce Collective Risk',
    description: 'Permit the long-term (10+ year) maintenance, bug fixes, and release of key supply chain dependencies to your organization.',
    icon: 'exclamation-triangle',
  },
  {
    title: 'Increase Collective Reliability',
    description: 'Facilite the combination of battle-tested, real world experiences by 300+ companies worldwide for continuous improvement.',
    icon: 'shield',
  },
  {
    title: 'Lower Barriers for Industry & Your Team',
    description: 'Easier hiring, technology deployment, and application-specific customization using the industry-standard framework.',
    icon: 'bars-arrow-down',
  },
];

// Landscape-only robot images (removed vertical/humanoid robots)
const robotImages = [
  { name: 'Dexory', src: 'https://nav2.org/_astro/dexory.b7e3bbfb.png' },
  { name: 'Polymath', src: 'https://nav2.org/_astro/polymath.185a35b6.png' },
  { name: 'NovaCarter', src: 'https://nav2.org/_astro/novacarter.054a1d29.png' },
  { name: 'Angsa', src: 'https://nav2.org/_astro/angsa.5c2eaea5.png' },
  { name: 'Birdseye', src: 'https://nav2.org/_astro/birdseye.a8d387b0.png' },
  { name: 'MPO 700', src: 'https://nav2.org/_astro/mpo_700.dd5d7314.png' },
  { name: 'Polymath Boat', src: 'https://nav2.org/_astro/polymath_boat.dd18210e.png' },
  { name: 'Rover', src: 'https://nav2.org/_astro/rover.e9944080.png' },
  { name: 'Botronics', src: 'https://nav2.org/_astro/botronics.b421d88f.png' },
  { name: 'Firefly', src: 'https://nav2.org/_astro/firefly.9ecc65db.png' },
  { name: 'Kiwibot', src: 'https://nav2.org/_astro/kiwibot.aade6ad2.png' },
  { name: 'Tailos', src: 'https://nav2.org/_astro/tailos.96525e80.png' },
  { name: 'Karelics', src: 'https://nav2.org/_astro/karelics2.e24ba062.png' },
  { name: 'Karelics 2', src: 'https://nav2.org/_astro/karelics.6670d7cd.png' },
  { name: 'Datavision', src: 'https://nav2.org/_astro/datavision.4befd4a6.png' },
  { name: 'TurtleBot 4', src: 'https://nav2.org/_astro/tb4.c9a9a018.png' },
  { name: 'Seasony', src: 'https://nav2.org/_astro/seasony.7798955d.png' },
  { name: 'Brisa', src: 'https://nav2.org/_astro/brisa.2b93a8e3.png' },
  { name: 'Torch', src: 'https://nav2.org/_astro/torch.7b697a35.png' },
  { name: 'TurtleBot 3', src: 'https://nav2.org/_astro/tb3.78f42d15.png' },
  { name: 'Unitree Go2', src: 'https://nav2.org/_astro/go2.fd6b23b1.png' },
  { name: 'Barn Owl', src: 'https://nav2.org/_astro/barnowl.4bafcc69.png' },
  { name: 'TRI', src: 'https://nav2.org/_astro/tri.c5bca68f.png' },
  { name: 'WYCA', src: 'https://nav2.org/_astro/wyca.82ef10f6.png' },
  { name: 'Elroy', src: 'https://nav2.org/_astro/elroy.ac34a6e5.png' },
  { name: 'TurtleBot 2', src: 'https://nav2.org/_astro/tb2.9aa4c907.png' },
  { name: 'ACFR', src: 'https://nav2.org/_astro/ACFR.b105bb99.png' },
  { name: 'ROSbot XL', src: 'https://nav2.org/_astro/rosbot_xl.9180a9a2.png' },
  { name: 'Saxion', src: 'https://nav2.org/_astro/saxion.4a0ff6c8.jpeg' },
];

// Split images into two rows (no duplicates - 15 images per row)
const row1Images = robotImages.slice(0, 15);
const row2Images = robotImages.slice(15);
---

<BaseLayout title="Home">
  <!-- Hero Section -->
  <section class="relative overflow-x-clip bg-gradient-to-br from-nav2-blue/10 via-white to-nav2-blue-light/10 dark:from-nav2-blue-dark/30 dark:via-gray-900 dark:to-gray-900">
    <!-- Low-poly triangular mesh background -->
    <LowPolyBackground />
    <div class="section-container py-16 md:py-24 lg:py-32 relative z-10">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <!-- Text Content -->
        <div class="text-center lg:text-left">
          <h1 class="text-4xl md:text-5xl lg:text-6xl xl:text-7xl font-bold mb-4">
            <span class="text-nav2-blue dark:text-nav2-blue-light">Your Friendly</span><br />
            <span class="text-nav2-grey dark:text-white">Neighborhood Navigators</span>
          </h1>
          <p class="text-nav2-blue dark:text-nav2-blue-light font-semibold text-xl md:text-2xl mb-4 tracking-wide">
            Democratizing Mobile Robotics
          </p>
          <p class="text-lg md:text-xl lg:text-2xl text-gray-600 dark:text-gray-300 mb-8 max-w-xl mx-auto lg:mx-0">
            Accelerating robotics productization and applied research through professional-quality,
            open-source navigation technology and commercial services.
          </p>
          <div class="flex flex-wrap gap-4 justify-center lg:justify-start">
            <a href="/sponsorship" class="btn-primary text-lg px-8 py-4">
              Become a Sponsor
            </a>
            <a href="/support" class="btn-outline text-lg px-8 py-4">
              Get Commercial Support
            </a>
          </div>
        </div>

        <!-- Balloon Animation -->
        <div class="flex justify-center lg:justify-end">
          <HeroBalloon />
        </div>
      </div>
    </div>

    <!-- Decorative Elements -->
    <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-white dark:from-gray-900 to-transparent"></div>
  </section>

  <!-- Video Section -->
  <section class="section-padding bg-white dark:bg-gray-900">
    <div class="section-container">
      <div class="text-center mb-12 animate-on-scroll">
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-nav2-grey dark:text-white mb-4">
          Our Customers, Partners, & Users
        </h2>
        <p class="text-lg md:text-xl text-gray-600 dark:text-gray-300 max-w-2xl mx-auto">
          Teams around the world use our solutions to power their robots.
        </p>
      </div>
      <div class="animate-on-scroll">
        <HeroVideo src="/videos/hero.mp4" />
      </div>
    </div>
  </section>

  <!-- Blue accent divider -->
  <div class="h-1 bg-gradient-to-r from-transparent via-nav2-blue to-transparent"></div>

  <!-- Quote Section -->
  <section class="bg-nav2-grey text-white py-16 md:py-20">
    <div class="section-container">
      <div class="max-w-6xl mx-auto flex items-center gap-6 md:gap-10 animate-on-scroll">
        <!-- ROS Logo (9 dots only, cropped) -->
        <div class="flex-shrink-0 hidden md:block relative self-stretch">
          <!-- Sticker Badge -->
          <div class="absolute -top-[4px] -left-24 transform -rotate-[22deg] bg-nav2-blue text-white px-8 py-3 rounded-xl shadow-lg text-lg font-bold z-10">
            ROS Approved
          </div>
          <!-- Wrapper to crop to just the 9 dots (left side of image) -->
          <div class="h-full w-72 lg:w-80 xl:w-96 overflow-hidden flex items-center">
            <img src="/images/ros-logo-white.png" alt="ROS 9 dots" class="h-full object-cover object-left scale-[0.75] origin-left ml-[10px]" />
          </div>
        </div>
        <blockquote class="text-center md:text-left flex-1">
          <p class="text-base md:text-lg lg:text-xl xl:text-2xl font-medium italic mb-6 leading-relaxed">
            "Open Navigation has demonstrated an exceptional talent for both community management and software engineering; growing the project, interacting promptly with every bug report and feature request, while simultaneously leading the development of important new features and capabilities.
          </p>
          <p class="text-base md:text-lg lg:text-xl xl:text-2xl font-medium italic mb-6 leading-relaxed">
            Through Open Navigation's leadership, Nav2 continues to be the go-to solution for mobile robot navigation in any environment and provides a solid foundation for numerous new robotics ventures. I support their mission to power the democratization of mobile robotics technology."
          </p>
          <footer class="text-nav2-blue-light text-lg md:text-xl">
            <cite class="not-italic font-semibold">Geoff Biggs</cite>
            <span class="text-gray-400"> &mdash; CTO, Open Source Robotics Foundation</span>
          </footer>
        </blockquote>
      </div>
    </div>
  </section>

  <!-- Blue accent divider -->
  <div class="h-1 bg-gradient-to-r from-transparent via-nav2-blue to-transparent"></div>

  <!-- Features Section -->
  <section class="section-padding bg-gray-50 dark:bg-gray-800">
    <div class="section-container">
      <div class="text-center mb-16 animate-on-scroll">
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-nav2-grey dark:text-white mb-4">
          Why Sponsor Nav2?
        </h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        {features.map((feature, index) => (
          <div class="animate-on-scroll glass-card glass-card-hover p-6 md:p-8 rounded-xl" style={`animation-delay: ${index * 100}ms`}>
            <div class="w-14 h-14 bg-nav2-blue/10 rounded-xl flex items-center justify-center mb-5">
              <svg class="w-7 h-7 text-nav2-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                {feature.icon === 'exclamation-triangle' && (
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                )}
                {feature.icon === 'shield' && (
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                )}
                {feature.icon === 'bars-arrow-down' && (
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4.5h14.25M3 9h9.75M3 13.5h9.75m4.5-4.5v12m0 0l-3.75-3.75M17.25 21l3.75-3.75" />
                )}
                {feature.icon === 'sparkles' && (
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z" />
                )}
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-nav2-grey dark:text-white mb-3">{feature.title}</h3>
            <p class="text-gray-600 dark:text-gray-300">{feature.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Robot Partners Section -->
  <section class="section-padding bg-white dark:bg-gray-900 overflow-hidden">
    <div class="section-container">
      <div class="text-center mb-12 animate-on-scroll">
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-nav2-grey dark:text-white mb-4">
          Trusted by Industry Leaders
        </h2>
        <p class="text-lg md:text-xl text-gray-600 dark:text-gray-300 max-w-2xl mx-auto">
          Powering mobile robots across agriculture, logistics, healthcare, and more.
        </p>
      </div>
    </div>

    <!-- Carousel rows - full width, outside container -->
    <div class="carousel-wrapper">
      <!-- Carousel Row 1 - scrolls left continuously -->
      <div class="relative mb-6">
        <div class="carousel-row carousel-left flex gap-4">
          {[...row1Images, ...row1Images].map((robot, i) => (
            <div class="relative flex-shrink-0 w-48 h-32 bg-gray-50 dark:bg-gray-800 rounded-xl overflow-hidden hover:shadow-lg transition-shadow">
              <img src={robot.src} alt={robot.name} class="w-full h-full object-cover" loading="lazy" />
              <div class="absolute inset-0 bg-nav2-blue/25 pointer-events-none"></div>
            </div>
          ))}
        </div>
      </div>

      <!-- Carousel Row 2 - scrolls right continuously -->
      <div class="relative">
        <div class="carousel-row carousel-right flex gap-4">
          {[...row2Images, ...row2Images].map((robot, i) => (
            <div class="relative flex-shrink-0 w-48 h-32 bg-gray-50 dark:bg-gray-800 rounded-xl overflow-hidden hover:shadow-lg transition-shadow">
              <img src={robot.src} alt={robot.name} class="w-full h-full object-cover" loading="lazy" />
              <div class="absolute inset-0 bg-nav2-blue/25 pointer-events-none"></div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Sponsors Section -->
  <section class="section-padding bg-nav2-blue/5 dark:bg-gray-800 relative overflow-hidden">
    <!-- Backdrop Image -->
    <div class="absolute inset-0 flex items-center justify-center opacity-[0.03] dark:opacity-[0.02]">
      <img src="/images/grey-backdrop.png" alt="" class="w-3/4 h-auto object-contain" aria-hidden="true" />
    </div>
    <div class="section-container relative z-10">
      <div class="text-center mb-4 animate-on-scroll">
        <p class="text-lg md:text-xl text-gray-600 dark:text-gray-300 max-w-2xl mx-auto mb-8">
          Thank you to our sponsors who help keep Nav2 free and open for everyone.
        </p>
      </div>

      <div class="animate-on-scroll">
        <SponsorsShowcase />
      </div>

      <div class="text-center mt-12 animate-on-scroll">
        <a href="/sponsorship" class="btn-primary text-lg px-8 py-4">
          Become a Sponsor
        </a>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="bg-nav2-grey text-white py-16 md:py-20">
    <div class="section-container text-center">
      <div class="animate-on-scroll">
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-6">
          Ready to Get Started?
        </h2>
        <p class="text-lg md:text-xl text-gray-300 max-w-2xl mx-auto mb-8">
          Whether you need expert support, want to sponsor the project, or just want to learn more, we're here to help.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href="/contact" class="btn-primary text-lg px-8 py-4">
            Contact Us
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Scroll animation styles */
  .animate-on-scroll {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }

  .animate-on-scroll.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Carousel wrapper - full width */
  .carousel-wrapper {
    width: 100vw;
    margin-left: calc(-50vw + 50%);
    overflow: hidden;
  }

  /* Carousel animations - seamless continuous loop */
  .carousel-row {
    display: flex;
    width: max-content;
    animation-duration: 30s;
    animation-timing-function: linear;
    animation-iteration-count: infinite;
  }

  .carousel-left {
    animation-name: scroll-left;
  }

  .carousel-right {
    animation-name: scroll-right;
  }

  @keyframes scroll-left {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @keyframes scroll-right {
    0% {
      transform: translateX(-50%);
    }
    100% {
      transform: translateX(0);
    }
  }

  .carousel-row:hover {
    animation-play-state: paused;
  }

  @media (prefers-reduced-motion: reduce) {
    .carousel-row {
      animation: none;
    }
  }
</style>

<script>
  // Intersection Observer for scroll animations
  const observerOptions = {
    root: null,
    rootMargin: '0px',
    threshold: 0.1
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
      }
    });
  }, observerOptions);

  // Observe all elements with animate-on-scroll class
  document.querySelectorAll('.animate-on-scroll').forEach((el) => {
    observer.observe(el);
  });
</script>
