---
import BaseLayout from '@layouts/BaseLayout.astro';
import SponsorsShowcase from '@components/SponsorsShowcase.astro';
import LowPolyBackground from '@components/LowPolyBackground.astro';

const base = import.meta.env.BASE_URL;

const projects = [
  { name: 'Nav2', description: 'The premier mobile robot navigation framework' },
  { name: 'docs.nav2.org', description: 'Exhaustive configuration, tuning, getting started, and tutorials' },
  { name: 'SLAM Toolbox', description: 'State-of-the-art 2D SLAM solution' },
  { name: 'Opennav Coverage', description: 'Complete coverage planning task server and navigation integration' },
  { name: 'Robot Localization', description: 'Multi-sensor fusion for state estimation' },
  { name: 'rclcpp', description: 'Core ROS 2 C++ client library' },
  { name: 'Spatio-Temporal Voxel Layer', description: 'Temporal sparse volumetric perception integration' },
  { name: 'Non-Persistent Voxel Layer', description: 'Non-persisting perception integration' },
  { name: 'Vision Msgs', description: 'AI and detection vision messages' },
  { name: 'Radar Msgs', description: 'Radar messages' },
  { name: 'Perception PCL', description: 'PCL ROS integration' },
  { name: 'Perception Open3D', description: 'Open3D ROS integration' },
];
---

<BaseLayout title="About Us" description="Learn about Open Navigation LLC and our mission to democratize mobile robotics.">
  <!-- Hero -->
  <section class="relative overflow-x-clip bg-gradient-to-br from-nav2-blue/10 via-white to-nav2-blue-light/10 dark:from-nav2-blue-dark/30 dark:via-gray-900 dark:to-gray-900 py-16 md:py-24">
    <LowPolyBackground />
    <div class="section-container relative z-10">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="text-4xl md:text-5xl font-bold text-nav2-grey dark:text-white mb-6">
          About <span class="text-nav2-blue dark:text-nav2-blue-light">Open Navigation</span>
        </h1>
        <p class="text-lg md:text-xl text-gray-600 dark:text-gray-300">
          Our mission is to accelerate robotics commercialization and applied research via the democratization of mobile robotics technologies by providing professional-quality navigation technology and commercial services. We also aim to establish open, community-driven collaborations within and between industry and academia to develop industry standardized references and leading technologies.
        </p>
      </div>
    </div>
    <div class="absolute bottom-0 left-0 right-0 h-16 bg-gradient-to-t from-white dark:from-gray-900 to-transparent"></div>
  </section>

  <!-- Projects We Maintain -->
  <section class="section-padding bg-white dark:bg-gray-900">
    <div class="section-container">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-2xl md:text-3xl font-bold text-nav2-grey dark:text-white mb-4 text-center animate-on-scroll">
          Projects We Developed & Maintain
        </h2>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {projects.map((project, index) => (
            <div class="glass-card glass-card-hover rounded-xl p-6 animate-on-scroll" style={`animation-delay: ${index * 50}ms`}>
              <h3 class="text-xl font-semibold text-nav2-grey dark:text-white mb-2">{project.name}</h3>
              <p class="text-gray-600 dark:text-gray-300">{project.description}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Sponsors Section -->
  <section class="section-padding bg-gray-50 dark:bg-gray-800 relative overflow-hidden">
    <!-- Backdrop Image -->
    <div class="absolute inset-0 flex items-center justify-center opacity-[0.03] dark:opacity-[0.02]">
      <img src={`${import.meta.env.BASE_URL}images/grey-backdrop.png`} alt="" class="w-3/4 h-auto object-contain" aria-hidden="true" />
    </div>
    <div class="section-container relative z-10">
      <div class="text-center mb-4 animate-on-scroll">
        <p class="text-lg md:text-xl text-gray-600 dark:text-gray-300 max-w-2xl mx-auto mb-8">
          Thank you to our sponsors who support the development of Nav2 and the broader mobile robotics ecosystem.
        </p>
      </div>
      <div class="animate-on-scroll">
        <SponsorsShowcase />
      </div>
      <div class="text-center mt-10 animate-on-scroll">
        <a href={`${base}sponsorship`} class="btn-outline">
          Learn About Sponsorship
        </a>
      </div>
    </div>
  </section>

  <!-- Leadership -->
  <section class="section-padding bg-white dark:bg-gray-900">
    <div class="section-container">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-2xl md:text-3xl font-bold text-nav2-grey dark:text-white mb-12 text-center animate-on-scroll">
          Leadership
        </h2>

        <div class="glass-card rounded-2xl p-8 md:p-12 animate-on-scroll">
          <div class="flex flex-col md:flex-row gap-8 items-center md:items-start">
            <div class="w-48 h-48 rounded-full overflow-hidden flex-shrink-0 shadow-lg">
              <img
                src={`${import.meta.env.BASE_URL}images/steve-macenski.jpg`}
                alt="Steve Macenski"
                class="w-full h-full object-cover"
              />
            </div>

            <div class="text-center md:text-left">
              <h3 class="text-2xl font-bold text-nav2-grey dark:text-white mb-2">Steve Macenski</h3>
              <p class="text-nav2-blue dark:text-nav2-blue-light font-medium mb-4">CEO & Chief Navigator</p>

              <p class="text-gray-600 dark:text-gray-300 mb-6">
                Steve is a seasoned engineering leader and robotics engineer with a decade of experience in robotics. He is an open information, open source, and community advocate. 

                He is a ‘full-stack roboticist’ with significant contributions in planning, optimal control, perception, architecture, localization, tooling, and more. He maintains critical projects such as rclcpp, Nav2, Robot Localization, SLAM Toolbox, Vision and Radar Messages, and more.
              </p>

              <p class="text-gray-600 dark:text-gray-300 mb-6">
                He has previously been a long-term member of the ROS 2 Technical Steering Committee (TSC) and the Community Representative of the OSRF Technical Governance Committee (TGC), demonstrating substantial influence in
                robotics technical development and community standards.
              </p>

              <!-- Social Links -->
              <div class="flex flex-wrap gap-4 justify-center md:justify-start">
                <a href="https://github.com/stevemacenski" target="_blank" rel="noopener noreferrer" class="w-10 h-10 bg-nav2-blue/10 hover:bg-nav2-blue/20 rounded-lg flex items-center justify-center transition-colors" title="GitHub">
                  <svg class="w-5 h-5 text-nav2-blue" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                  </svg>
                </a>
                <a href="https://www.linkedin.com/in/steve-macenski-41a985101/" target="_blank" rel="noopener noreferrer" class="w-10 h-10 bg-nav2-blue/10 hover:bg-nav2-blue/20 rounded-lg flex items-center justify-center transition-colors" title="LinkedIn">
                  <svg class="w-5 h-5 text-nav2-blue" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                </a>
                <a href="https://www.youtube.com/channel/UC7b1d0UPj4rQghUsh_rI1sA/videos" target="_blank" rel="noopener noreferrer" class="w-10 h-10 bg-nav2-blue/10 hover:bg-nav2-blue/20 rounded-lg flex items-center justify-center transition-colors" title="YouTube">
                  <svg class="w-5 h-5 text-nav2-blue" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                  </svg>
                </a>
                <a href="https://www.steve.macenski.com/" target="_blank" rel="noopener noreferrer" class="w-10 h-10 bg-nav2-blue/10 hover:bg-nav2-blue/20 rounded-lg flex items-center justify-center transition-colors" title="Website">
                  <svg class="w-5 h-5 text-nav2-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/>
                  </svg>
                </a>
                <a href="https://scholar.google.com/citations?user=MGZmVmwAAAAJ&hl=en" target="_blank" rel="noopener noreferrer" class="w-10 h-10 bg-nav2-blue/10 hover:bg-nav2-blue/20 rounded-lg flex items-center justify-center transition-colors" title="Google Scholar">
                  <svg class="w-5 h-5 text-nav2-blue" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M5.242 13.769L0 9.5 12 0l12 9.5-5.242 4.269C17.548 11.249 14.978 9.5 12 9.5c-2.977 0-5.548 1.748-6.758 4.269zM12 10a7 7 0 1 0 0 14 7 7 0 0 0 0-14z"/>
                  </svg>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Location -->
  <section class="section-padding bg-white dark:bg-gray-900">
    <div class="section-container">
      <div class="max-w-2xl mx-auto text-center animate-on-scroll">
        <h2 class="text-2xl md:text-3xl font-bold text-nav2-grey dark:text-white mb-6">
          Where We're Based
        </h2>
        <p class="text-lg text-gray-600 dark:text-gray-300 mb-4">
          Open Navigation LLC is headquartered in San Francisco, California, USA.
        </p>
        <p class="text-gray-500 dark:text-gray-400">
          We work with companies worldwide in all timezones and are available for remote and onsite collaboration.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-nav2-grey text-white py-16">
    <div class="section-container text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-6">
        Want to Work With Us?
      </h2>
      <p class="text-lg text-gray-300 max-w-2xl mx-auto mb-8">
        Whether you're looking to sponsor, need consulting support, or just want to say hello,
        we'd love to hear from you.
      </p>
      <a href={`${base}contact`} class="btn-primary">
        Get in Touch
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .animate-on-scroll {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }

  .animate-on-scroll.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const observerOptions = {
    root: null,
    rootMargin: '0px',
    threshold: 0.1
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
      }
    });
  }, observerOptions);

  document.querySelectorAll('.animate-on-scroll').forEach((el) => {
    observer.observe(el);
  });
</script>
