---
import BaseLayout from '@layouts/BaseLayout.astro';
import ContactForm from '@components/ContactForm.astro';
import LowPolyBackground from '@components/LowPolyBackground.astro';

// Get interest from URL params
const interest = Astro.url.searchParams.get('interest') as 'sponsorship' | 'consulting' | null;
---

<BaseLayout title="Contact" description="Get in touch with Open Navigation LLC for sponsorship, consulting, or general inquiries.">
  <!-- Hero -->
  <section class="relative overflow-x-clip bg-gradient-to-br from-nav2-blue/10 via-white to-nav2-blue-light/10 dark:from-nav2-blue-dark/30 dark:via-gray-900 dark:to-gray-900 py-16 md:py-24">
    <LowPolyBackground />
    <div class="section-container text-center relative z-10">
      <h1 class="text-4xl md:text-5xl font-bold text-nav2-grey dark:text-white mb-6">
        Get in <span class="text-nav2-blue dark:text-nav2-blue-light">Touch</span>
      </h1>
      <p class="text-lg md:text-xl text-gray-600 dark:text-gray-300 max-w-2xl mx-auto">
        Have a question about sponsorship, need commercial support, or just want to say hello and tell us about how you're using our software?
        We'd love to hear from you.
      </p>
    </div>
    <div class="absolute bottom-0 left-0 right-0 h-16 bg-gradient-to-t from-white dark:from-gray-900 to-transparent"></div>
  </section>

  <!-- Contact Section -->
  <section class="section-padding bg-white dark:bg-gray-900">
    <div class="section-container">
      <div class="grid lg:grid-cols-3 gap-12 max-w-6xl mx-auto">
        <!-- Contact Info -->
        <div class="lg:col-span-1 animate-on-scroll">
          <h2 class="text-2xl font-bold text-nav2-grey dark:text-white mb-6">Contact Info</h2>

          <div class="space-y-6">
            <div>
              <h3 class="font-semibold text-nav2-grey dark:text-white mb-2">General Inquiries</h3>
              <a href="mailto:info@opennav.org" class="text-nav2-blue hover:underline">
                info@opennav.org
              </a>
            </div>

            <div>
              <h3 class="font-semibold text-nav2-grey dark:text-white mb-2">Location</h3>
              <p class="text-gray-600 dark:text-gray-300">
                San Francisco, California<br />
                United States
              </p>
            </div>
          </div>
        </div>

        <!-- Contact Form -->
        <div class="lg:col-span-2 animate-on-scroll" style="animation-delay: 100ms">
          <div class="glass-card rounded-2xl p-6 md:p-8">
            <h2 class="text-2xl font-bold text-nav2-grey dark:text-white mb-6">Send Us a Message</h2>
            <ContactForm defaultInterest={interest || ''} />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section-padding bg-gray-50 dark:bg-gray-800">
    <div class="section-container">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-2xl md:text-3xl font-bold text-nav2-grey dark:text-white mb-8 text-center animate-on-scroll">
          Frequently Asked Questions
        </h2>

        <div class="space-y-4">
          <details class="glass-card rounded-lg group animate-on-scroll" style="animation-delay: 100ms">
            <summary class="flex items-center justify-between p-6 cursor-pointer">
              <span class="font-semibold text-nav2-grey dark:text-white">Do you offer training, workshops, or lectures?</span>
              <svg class="w-5 h-5 text-nav2-blue transform group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-6 text-gray-600 dark:text-gray-300">
              Yes! We offer custom training and workshops for teams. Contact us to discuss your needs.
            </div>
          </details>

          <details class="glass-card rounded-lg group animate-on-scroll" style="animation-delay: 200ms">
            <summary class="flex items-center justify-between p-6 cursor-pointer">
              <span class="font-semibold text-nav2-grey dark:text-white">Can you help with non-Nav2 projects?</span>
              <svg class="w-5 h-5 text-nav2-blue transform group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-6 text-gray-600 dark:text-gray-300">
              Our expertise spans all of ROS 2 and mobile robotics. While our focus is generally Nav2-related work, we can complete other robotics projects as well including software architecture, ROS 2 porting, mobility algorithm development, advising, and more.
            </div>
          </details>

          <details class="glass-card rounded-lg group animate-on-scroll" style="animation-delay: 100ms">
            <summary class="flex items-center justify-between p-6 cursor-pointer">
              <span class="font-semibold text-nav2-grey dark:text-white">Do you offer other services or help not listed?</span>
              <svg class="w-5 h-5 text-nav2-blue transform group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-6 text-gray-600 dark:text-gray-300">
              Yes! We build bespoke packages and agreements and are happy to customize to your needs. If we're not the right people for the task, we'll connect you to the right folks in our network that are. Contact us to discuss your needs.
            </div>
          </details>

          <details class="glass-card rounded-lg group animate-on-scroll" style="animation-delay: 100ms">
            <summary class="flex items-center justify-between p-6 cursor-pointer">
              <span class="font-semibold text-nav2-grey dark:text-white">How should I reach out if I want to contribute to Nav2?</span>
              <svg class="w-5 h-5 text-nav2-blue transform group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-6 text-gray-600 dark:text-gray-300">
              Please reach out via the Nav2 slack (invite link at docs.nav2.org and in the project README) or look over the Nav2 issue tracker to find potential contributions of interest. Better yet, file a ticket about a new feature you have in mind!
            </div>
          </details>

        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .animate-on-scroll {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }

  .animate-on-scroll.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const observerOptions = {
    root: null,
    rootMargin: '0px',
    threshold: 0.1
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
      }
    });
  }, observerOptions);

  document.querySelectorAll('.animate-on-scroll').forEach((el) => {
    observer.observe(el);
  });
</script>
