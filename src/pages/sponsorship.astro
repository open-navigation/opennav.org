---
import BaseLayout from '@layouts/BaseLayout.astro';
import SponsorCard from '@components/SponsorCard.astro';
import LowPolyBackground from '@components/LowPolyBackground.astro';

const base = import.meta.env.BASE_URL;

const generalBenefits = [
  'Commitment to keep Nav2 open and free',
  'Continued development of capabitilities and applications in Nav2',
  'Resolution of identified bugs or defects',
  'High-quality knowledge sharing, documentation, and technical communication',
  'Enforcement of high quality standards, security, release, and versioning stability',
  'Creating the environment for collaborations with students, researchers, and companies',
  'Access to maintainers for contracting opportunities',
  'Prioritized responses across email, Slack, and public tickets',
  'Regular project updates and syncs',
  'Reciprocal access: a bidirectional relationship sharing needs and feedback for roadmap planning',
];

const tiers = {
  silver: {
    name: 'Silver',
    benefits: [
      'Small company logo/link on website, repository, and presentations',
      'Up to quarterly private meetings with maintainers',
      'Commitment to keep Nav2 open and free',
      'Access to maintainers for contracting opportunities',
      'Prioritized responses across email, Slack, and public tickets',
      'Regular project updates and syncs',
      'Reciprocal access: a bidirectional relationship sharing uses & feedback for roadmap planning',
    ],
  },
  gold: {
    name: 'Gold',
    benefits: [
      'Medium company logo/link on website, repository, and presentations',
      'Up to monthly private meetings with maintainers',
      'Direct access to expertise on Nav2-specific questions',
      'First access to new features with integration support',
      'All previous benefits from Silver',
      { text: 'Private Slack access for rapid communication', excluded: true },
      { text: 'Separate private project board', excluded: true },
    ],
  },
  platinum: {
    name: 'Platinum',
    benefits: [
      'Large, prominent logo/link across all channels',
      'Up to biweekly meetings plus as-needed access',
      'Unlimited expertise access on any topic',
      'Expanded roadmap influence',
      'Separate private Slack access for rapid communication',
      'Separate private project board',
      'First access to features, choice in white papers and case studies',
      'Customizable benefits negotiation',
    ],
  },
};
---

<BaseLayout title="Sponsorship" description="Support Nav2 development and gain access to expert maintainers through our sponsorship program.">
  <!-- Hero -->
  <section class="relative overflow-x-clip bg-gradient-to-br from-nav2-blue/10 via-white to-nav2-blue-light/10 dark:from-nav2-blue-dark/30 dark:via-gray-900 dark:to-gray-900 py-16 md:py-24">
    <LowPolyBackground />
    <div class="section-container text-center relative z-10">
      <h1 class="text-4xl md:text-5xl font-bold text-nav2-grey dark:text-white mb-6">
        Sponsor <span class="text-nav2-blue dark:text-nav2-blue-light">Nav2</span>
      </h1>
      <p class="text-lg md:text-xl text-gray-600 dark:text-gray-300 max-w-3xl mx-auto">
        Join world leading organizations in supporting the most widely-adopted mobile robot navigation framework.
        Your sponsorship helps keep Nav2 free and continuously improving.
      </p>
    </div>
    <div class="absolute bottom-0 left-0 right-0 h-16 bg-gradient-to-t from-white dark:from-gray-900 to-transparent"></div>
  </section>

  <!-- About Open Navigation & Why Sponsor -->
  <section class="section-padding bg-white dark:bg-gray-900">
    <div class="section-container">
      <div class="max-w-4xl mx-auto">
        <!-- About Section -->
        <div class="mb-12 animate-on-scroll">
          <p class="text-gray-600 dark:text-gray-300 text-lg leading-relaxed mb-4">
            Open Navigation LLC was formed in 2023 to lead, develop, and support the Nav2 navigation framework. Nav2 is utilized by <strong class="text-nav2-grey dark:text-white">300+ companies worldwide</strong> from agriculture and mining to warehousing automation and advanced research. It has received significant attention due to its modern and expanding capabilities, high quality and configurability, and professional maintenance and support.
          </p>
          <p class="text-gray-600 dark:text-gray-300 text-lg leading-relaxed">
            Additionally, the Nav2 community drives ROS 2 adoption and are often the first to find bugs critical to ROS users more broadly — creating a more stable and effective ROS for all.
          </p>
        </div>

        <!-- Why Sponsor Section -->
        <div class="mb-12 animate-on-scroll" style="animation-delay: 100ms">
          <p class="text-gray-600 dark:text-gray-300 text-lg leading-relaxed mb-4">
            We seek sponsorship from organizations relying upon ROS 2 and/or Nav2 for their products and services to enable long-term stability of the critical capability within your systems. Financing Nav2 and its related packages provides a sustainable avenue to continue to reliably merge changes on a rapid timeline, resolve software defects, develop additional capabilities, and perform the thankless maintenance tasks behind the scenes.
          </p>
          <p class="text-gray-600 dark:text-gray-300 text-lg leading-relaxed">
            In exchange, sponsors receive prioritized responses and expanded private access to Open Navigation LLC staff and expertise, in addition to other benefits including publicity and roadmap influence. <strong class="text-nav2-blue dark:text-nav2-blue-light">If you leverage ROS 2 or Nav2, sponsoring Open Navigation is in your own best interest!</strong>
          </p>
        </div>

        <!-- Why Sponsor Cards -->
        <div class="animate-on-scroll" style="animation-delay: 200ms">
          <h2 class="text-2xl md:text-3xl font-bold text-nav2-grey dark:text-white mb-8 text-center">
            Why A Sponsorship Model?
          </h2>

          <div class="grid md:grid-cols-2 gap-8">
            <div class="glass-card glass-card-hover rounded-xl p-6">
              <h3 class="text-xl font-semibold text-nav2-grey dark:text-white mb-3">Alignment of Interests</h3>
              <p class="text-gray-600 dark:text-gray-300">
                Your sponsorship directly supports the development of features you need.
                Sponsors have direct input into the roadmap and priorities.
              </p>
            </div>

            <div class="glass-card glass-card-hover rounded-xl p-6">
              <h3 class="text-xl font-semibold text-nav2-grey dark:text-white mb-3">Expert Access</h3>
              <p class="text-gray-600 dark:text-gray-300">
                Get direct access to the maintainers who built Nav2. Reduce your development
                time with expert guidance and support.
              </p>
            </div>

            <div class="glass-card glass-card-hover rounded-xl p-6">
              <h3 class="text-xl font-semibold text-nav2-grey dark:text-white mb-3">Industry Recognition</h3>
              <p class="text-gray-600 dark:text-gray-300">
                Showcase your company's commitment to open-source robotics. Your logo appears
                across Nav2's documentation, repository, and presentations.
              </p>
            </div>

            <div class="glass-card glass-card-hover rounded-xl p-6">
              <h3 class="text-xl font-semibold text-nav2-grey dark:text-white mb-3">Reduce Risk</h3>
              <p class="text-gray-600 dark:text-gray-300">
                Ensure the long-term sustainability of the navigation stack your products
                depend on. Support continued maintenance and improvements.
              </p>
            </div>

            <div class="glass-card glass-card-hover rounded-xl p-6">
              <h3 class="text-xl font-semibold text-nav2-grey dark:text-white mb-3">Easy to Use</h3>
              <p class="text-gray-600 dark:text-gray-300">
                Alignment to make software easy to use — rather than obfuscating software
                to drive consulting business.
              </p>
            </div>

            <div class="glass-card glass-card-hover rounded-xl p-6">
              <h3 class="text-xl font-semibold text-nav2-grey dark:text-white mb-3">Open-Source & Free</h3>
              <p class="text-gray-600 dark:text-gray-300">
                Alignment to keep software free and open for all. Forever.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- General Benefits -->
  <section class="section-padding bg-white dark:bg-gray-900">
    <div class="section-container">
      <div class="max-w-3xl mx-auto animate-on-scroll">
        <h2 class="text-2xl md:text-3xl font-bold text-nav2-grey dark:text-white mb-4 text-center">
          All Sponsors Receive
        </h2>
        <p class="text-gray-600 dark:text-gray-300 text-center mb-8">
          Sponsoring Nav2 enables world-class experts to continue to provide proactive support to all end-users globally. It also allows for the continued development of key technologies to solve tangible problems facing the commercialization of robotics in a number of domains.
        </p>
        <div class="glass-card rounded-2xl p-8">
          <ul class="space-y-4">
            {generalBenefits.map((benefit) => (
              <li class="flex items-start gap-4">
                <div class="w-6 h-6 rounded-full bg-nav2-blue flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                </div>
                <span class="text-nav2-grey dark:text-gray-200 text-lg">{benefit}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Sponsor Thank You Banner -->
  <section class="bg-nav2-blue py-6">
    <div class="section-container">
      <p class="text-lg md:text-xl text-white font-semibold text-center">
        Please thank our sponsors for enabling these amazing benefits to the ROS 2 and Nav2 communities.
      </p>
    </div>
  </section>

  <!-- Sponsorship Tiers -->
  <section class="section-padding bg-gray-50 dark:bg-gray-800">
    <div class="section-container">
      <h2 class="text-2xl md:text-3xl font-bold text-nav2-grey dark:text-white mb-12 text-center animate-on-scroll">
        Sponsorship Tiers
      </h2>

      <div class="grid md:grid-cols-3 gap-8 max-w-6xl mx-auto items-stretch">
        <div class="animate-on-scroll h-full" style="animation-delay: 0ms">
          <SponsorCard
            name={tiers.silver.name}
            tier="silver"
            benefits={tiers.silver.benefits}
          />
        </div>
        <div class="animate-on-scroll h-full" style="animation-delay: 100ms">
          <SponsorCard
            name={tiers.gold.name}
            tier="gold"
            benefits={tiers.gold.benefits}
            highlighted
          />
        </div>
        <div class="animate-on-scroll h-full" style="animation-delay: 200ms">
          <SponsorCard
            name={tiers.platinum.name}
            tier="platinum"
            benefits={tiers.platinum.benefits}
          />
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-nav2-grey text-white py-16">
    <div class="section-container text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-6">
        Ready to Become a Sponsor?
      </h2>
      <p class="text-lg text-gray-300 max-w-2xl mx-auto mb-8">
        Contact us to discuss the best sponsorship option for your organization.
      </p>
      <a href={`${base}contact?interest=sponsorship`} class="btn-primary">
        Contact Us About Sponsorship
      </a>
      <p class="mt-6 text-gray-400">
        Or email us directly at <a href="mailto:sponsors@opennav.org" class="text-nav2-blue hover:underline">sponsors@opennav.org</a>
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .animate-on-scroll {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }

  .animate-on-scroll.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const observerOptions = {
    root: null,
    rootMargin: '0px',
    threshold: 0.1
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
      }
    });
  }, observerOptions);

  document.querySelectorAll('.animate-on-scroll').forEach((el) => {
    observer.observe(el);
  });
</script>
