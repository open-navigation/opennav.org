---
import BaseLayout from '@layouts/BaseLayout.astro';
import LowPolyBackground from '@components/LowPolyBackground.astro';

const services = [
  {
    title: 'Nav2 Development & Extension',
    description: 'Feature development or bug fixes; custom Nav2 servers, plugins, or behaviors to extend the framework for your specific needs.',
    icon: 'code',
  },
  {
    title: 'Mobility Algorithm Development',
    description: 'Custom perception, localization, planning, and control algorithms tailored to your application.',
    icon: 'cpu',
  },
  {
    title: 'ROS 2 & Nav2 Training',
    description: 'Hands-on training for your team on ROS 2 fundamentals, Nav2 configuration, and advanced topics.',
    icon: 'academic',
  },
  {
    title: 'ROS Solution Architecture',
    description: 'End-to-end ROS 2 system design, node architecture, and best practices for scalable robotics applications.',
    icon: 'puzzle',
  },
  {
    title: 'Nav2 Setup & Configuration',
    description: 'Get Nav2 running on your robot with optimized parameters, tuning, and validation.',
    icon: 'cog',
  },
  {
    title: 'ROS 2 Porting',
    description: 'Migrate your applications to ROS 2 with modern patterns, best practices, and performance optimizations from Day 1.',
    icon: 'arrows',
  },
  {
    title: 'ROS Driver Development',
    description: 'Custom ROS 2 drivers for sensors, actuators, and hardware interfaces with ongoing support.',
    icon: 'wrench',
  },
  {
    title: 'General Mobile Robotics Support',
    description: 'Broad robotics consulting covering system design, hardware selection, troubleshooting, and best practices.',
    icon: 'robot',
  },
  {
    title: 'Technology Proof of Concept',
    description: 'Rapid prototyping, feasibility studies, and technology demos to validate your robotics concepts before full development.',
    icon: 'lightbulb',
  },
];

const process = [
  {
    step: 1,
    title: 'Initial Consultation',
    description: 'We discuss your project requirements, challenges, and goals to understand how we can help. If we\'re not the right fit, we\'ll connect you with someone in our network that is.',
  },
  {
    step: 2,
    title: 'Proposal & Planning',
    description: 'We provide a detailed proposal outlining scope, timeline, deliverables, and budget for your project. We\'re happy to price based on hours worked, fixed-price project, or open partnerships for long-term clients.',
  },
  {
    step: 3,
    title: 'Development & Support',
    description: 'We work with your team to implement solution, with regular check-ins and updates at key milestones. Typically we work in a sandbox shared environment to protect client\'s unrelated IP.',
  },
  {
    step: 4,
    title: 'Delivery & Handoff',
    description: 'We deliver high quality, tested, and documented solutions and ensure your team is equipped to maintain and extend them. Absolutely no corners are cut and are of equal or higher quality than Nav2 itself.',
  },
];
---

<BaseLayout title="Get Support" description="Expert consulting and support services for mobile robot navigation.">
  <!-- Hero -->
  <section class="relative overflow-x-clip bg-gradient-to-br from-nav2-blue/10 via-white to-nav2-blue-light/10 dark:from-nav2-blue-dark/30 dark:via-gray-900 dark:to-gray-900 py-16 md:py-24">
    <LowPolyBackground />
    <div class="section-container text-center relative z-10">
      <h1 class="text-4xl md:text-5xl font-bold text-nav2-grey dark:text-white mb-6">
        Expert <span class="text-nav2-blue dark:text-nav2-blue-light">Navigation & ROS Support</span>
      </h1>
      <p class="text-lg md:text-xl text-gray-600 dark:text-gray-300 max-w-3xl mx-auto mb-8">
        Get direct access to the experts behind Nav2 with 10+ years of commercial robotics development experience.
        We offer consulting, development, advising support, configuration and validation, training and more.
      </p>
      <a href="/contact?interest=consulting" class="btn-primary">
        Contact Us
      </a>
    </div>
    <div class="absolute bottom-0 left-0 right-0 h-16 bg-gradient-to-t from-white dark:from-gray-900 to-transparent"></div>
  </section>

  <!-- Services -->
  <section class="section-padding bg-white dark:bg-gray-900">
    <div class="section-container">
      <h2 class="text-2xl md:text-3xl font-bold text-nav2-grey dark:text-white mb-12 text-center animate-on-scroll">
        Our Services
      </h2>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {services.map((service, index) => (
          <div class="glass-card glass-card-hover rounded-xl p-6 animate-on-scroll" style={`animation-delay: ${index * 100}ms`}>
            <div class="w-12 h-12 bg-nav2-blue/10 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-nav2-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                {service.icon === 'code' && (
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
                )}
                {service.icon === 'cpu' && (
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M3 9h2m-2 6h2m14-6h2m-2 6h2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z" />
                )}
                {service.icon === 'puzzle' && (
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z" />
                )}
                {service.icon === 'robot' && (
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                )}
                {service.icon === 'arrows' && (
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
                )}
                {service.icon === 'academic' && (
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222" />
                )}
                {service.icon === 'wrench' && (
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                )}
                {service.icon === 'cog' && (
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065zM15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                )}
                {service.icon === 'lightbulb' && (
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
                )}
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-nav2-grey dark:text-white mb-2">{service.title}</h3>
            <p class="text-gray-600 dark:text-gray-300">{service.description}</p>
          </div>
        ))}
      </div>

      <!-- Don't See Something -->
      <div class="mt-12 max-w-2xl mx-auto text-center animate-on-scroll">
        <div class="bg-nav2-grey rounded-xl p-8">
          <h3 class="text-xl font-semibold text-white mb-4">
            Don't See Something You Think You Should?
          </h3>
          <p class="text-gray-300 mb-6">
            Contact us to see how and if we can help! We typically focus on Nav2, Mobile Robotics,
            and the ROS Community, but if it's a slow month, we're up for a curve ball challenge
            to keep us on our toes.
          </p>
          <a href="/contact?interest=consulting" class="btn-primary">
            Get in Touch
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="section-padding bg-gray-50 dark:bg-gray-800">
    <div class="section-container">
      <h2 class="text-2xl md:text-3xl font-bold text-nav2-grey dark:text-white mb-4 text-center animate-on-scroll">
        How We Work
      </h2>

      <div class="max-w-4xl mx-auto">
        <div class="relative">
          <!-- Vertical line -->
          <div class="absolute left-8 top-0 bottom-0 w-0.5 bg-nav2-blue/20 hidden md:block"></div>

          <div class="space-y-8">
            {process.map((item, index) => (
              <div class="relative flex gap-6 animate-on-scroll" style={`animation-delay: ${index * 150}ms`}>
                <div class="flex-shrink-0 w-16 h-16 bg-nav2-blue rounded-full flex items-center justify-center text-white text-2xl font-bold z-10">
                  {item.step}
                </div>
                <div class="flex-grow pt-2">
                  <h3 class="text-xl font-semibold text-nav2-grey dark:text-white mb-2">{item.title}</h3>
                  <p class="text-gray-600 dark:text-gray-300">{item.description}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-nav2-grey text-white py-16">
    <div class="section-container text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-6">
        Let's Build Something Great
      </h2>
      <p class="text-lg text-gray-300 max-w-2xl mx-auto mb-8">
        Tell us about your project and we'll help you find the best path forward.
      </p>
      <a href="/contact?interest=consulting" class="btn-primary">
        Get Started
      </a>
      <p class="mt-6 text-gray-400">
        Or email us at <a href="mailto:info@opennav.org" class="text-nav2-blue hover:underline">info@opennav.org</a>
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .animate-on-scroll {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }

  .animate-on-scroll.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const observerOptions = {
    root: null,
    rootMargin: '0px',
    threshold: 0.1
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
      }
    });
  }, observerOptions);

  document.querySelectorAll('.animate-on-scroll').forEach((el) => {
    observer.observe(el);
  });
</script>
