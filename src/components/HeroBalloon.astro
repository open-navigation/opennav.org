---
// Animated hot air balloon component with NAV2 ground and shadow
// Note: The SVG has padding in its viewBox, so we scale up and use negative margins to crop
---

<div class="hero-balloon-container">
  <!-- Parallax wrapper for rising effect -->
  <div class="balloon-parallax">
    <!-- Floating Balloon with bobbing animation -->
    <div class="hero-balloon animate-float">
      <div class="balloon-wrapper">
        <img
          src={`${import.meta.env.BASE_URL}images/logo.svg`}
          alt="Nav2 Hot Air Balloon"
          class="balloon-img"
        />
      </div>
    </div>
  </div>

  <!-- Proud Maintainers Badge - right side, angled -->
  <div class="proud-badge">
    <span>By The Developers Of</span>
  </div>

  <!-- Shadow that pulses with the balloon -->
  <div class="balloon-shadow"></div>

  <!-- NAV2 Ground/Base -->
  <div class="nav2-ground">
    <img
      src={`${import.meta.env.BASE_URL}images/nav2-wordmark.png`}
      alt="NAV2"
      class="nav2-wordmark"
    />
  </div>
</div>

<style>
  .hero-balloon-container {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    min-height: 350px;
    padding-bottom: 40px;
    margin-top: -40px;
  }

  .balloon-parallax {
    will-change: transform, opacity;
    z-index: 10;
  }

  .hero-balloon {
    will-change: transform;
  }

  .balloon-wrapper {
    /* Crop the whitespace from the SVG by scaling up and hiding overflow */
    width: 280px;
    height: 350px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    filter: drop-shadow(0 25px 25px rgba(0, 0, 0, 0.15));
  }

  .balloon-img {
    /* Scale up significantly to fill the wrapper */
    width: 700px;
    height: auto;
    max-width: none;
  }

  .proud-badge {
    position: absolute;
    right: 50px;
    top: 12%;
    transform: rotate(12deg);
    background: #47c7ef;
    color: white;
    padding: 12px 32px;
    border-radius: 12px;
    font-size: 1.125rem;
    font-weight: 700;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
    z-index: 15;
    white-space: nowrap;
  }

  .balloon-shadow {
    position: absolute;
    bottom: 95px;
    left: 50%;
    transform: translateX(-50%);
    width: 140px;
    height: 35px;
    background: radial-gradient(ellipse at center, rgba(0, 0, 0, 0.45) 0%, rgba(0, 0, 0, 0.2) 40%, transparent 70%);
    border-radius: 50%;
    z-index: 6;
    animation: shadow-pulse 4s ease-in-out infinite;
  }

  @keyframes shadow-pulse {
    0%, 100% {
      transform: translateX(-50%) scale(1);
      opacity: 0.85;
    }
    50% {
      transform: translateX(-50%) scale(0.7);
      opacity: 0.5;
    }
  }

  .nav2-ground {
    position: absolute;
    bottom: -15px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 5;
  }

  .nav2-wordmark {
    width: 35vw;
    max-width: 280px;
    height: auto;
    object-fit: contain;
  }

  @media (min-width: 768px) {
    .hero-balloon-container {
      min-height: 420px;
      margin-top: -50px;
    }

    .balloon-wrapper {
      width: 350px;
      height: 440px;
    }

    .balloon-img {
      width: 880px;
    }

    .balloon-shadow {
      width: 180px;
      height: 45px;
      bottom: 105px;
    }

    .nav2-wordmark {
      width: 32vw;
      max-width: 350px;
    }

    .nav2-ground {
      bottom: -20px;
    }

    .proud-badge {
      right: 35px;
      top: 10%;
    }
  }

  @media (min-width: 1024px) {
    .hero-balloon-container {
      min-height: 480px;
      margin-top: -60px;
    }

    .balloon-wrapper {
      width: 420px;
      height: 520px;
    }

    .balloon-img {
      width: 1050px;
    }

    .balloon-shadow {
      width: 220px;
      height: 55px;
      bottom: 125px;
    }

    .nav2-wordmark {
      width: 28vw;
      max-width: 420px;
    }

    .nav2-ground {
      bottom: -25px;
    }

    .proud-badge {
      right: 25px;
      top: 7%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-balloon {
      animation: none;
    }
    .balloon-shadow {
      animation: none;
    }
  }
</style>

<script>
  // Rising balloon parallax - balloon floats up faster than scroll
  const parallaxWrapper = document.querySelector('.balloon-parallax') as HTMLElement;
  const shadow = document.querySelector('.balloon-shadow') as HTMLElement;
  const heroContainer = document.querySelector('.hero-balloon-container') as HTMLElement;

  if (parallaxWrapper && heroContainer) {
    const riseMultiplier = 1.25; // Balloon moves 1.25x faster than scroll
    const maxRise = 600; // Maximum pixels the balloon can rise

    function updateBalloonPosition() {
      const scrollY = window.scrollY;
      const containerTop = heroContainer.offsetTop;
      const containerHeight = heroContainer.offsetHeight;

      // Only apply effect when hero is in view
      if (scrollY < containerTop + containerHeight) {
        const rise = Math.min(scrollY * riseMultiplier, maxRise);
        const opacity = Math.max(1 - (scrollY / 300), 0);

        // Apply parallax to wrapper, keeping bobbing animation on balloon
        parallaxWrapper.style.transform = `translateY(-${rise}px)`;
        parallaxWrapper.style.opacity = String(opacity);

        // Shadow shrinks and fades as balloon rises
        if (shadow) {
          if (scrollY < 5) {
            // At top of page - let CSS animation run
            shadow.style.animation = '';
            shadow.style.transform = '';
            shadow.style.opacity = '';
          } else {
            // Scrolling - disable animation and control manually
            shadow.style.animation = 'none';
            const shadowScale = Math.max(1 - (scrollY / 300), 0.3);
            const shadowOpacity = Math.max(0.85 - (scrollY / 400), 0);
            shadow.style.transform = `translateX(-50%) scale(${shadowScale})`;
            shadow.style.opacity = String(shadowOpacity);
          }
        }
      }
    }

    // Initial update
    updateBalloonPosition();

    // Update on scroll with throttling
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          updateBalloonPosition();
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });

    // Respect reduced motion preference
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      parallaxWrapper.style.transform = '';
      parallaxWrapper.style.opacity = '';
      if (shadow) {
        shadow.style.transform = '';
        shadow.style.opacity = '';
      }
    }
  }
</script>

