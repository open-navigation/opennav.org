---
const currentYear = new Date().getFullYear();

const footerLinks = [
  {
    title: 'Navigation',
    links: [
      { href: '/', label: 'Home' },
      { href: '/sponsorship', label: 'Sponsorship' },
      { href: '/support', label: 'Get Support' },
    ],
  },
  {
    title: 'Company',
    links: [
      { href: '/about', label: 'About Us' },
      { href: '/contact', label: 'Contact' },
      { href: '/news', label: 'News' },
    ],
  },
  {
    title: 'Resources',
    links: [
      { href: 'https://nav2.org', label: 'Nav2 Docs', external: true },
      { href: 'https://github.com/ros-navigation/navigation2', label: 'GitHub', external: true },
    ],
  },
];
---

<footer class="bg-nav2-grey text-white">
  <div class="section-container py-12 md:py-16">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      <!-- Brand -->
      <div class="col-span-2 md:col-span-1">
        <h3 class="font-semibold mb-4">Open Navigation</h3>
        <p class="text-gray-300 text-sm mb-4">
          Democratizing mobile robotics technology through professional-quality open-source solutions.
        </p>
        <div class="text-gray-400 text-sm">
          <p>San Francisco, California, USA</p>
          <a href="mailto:info@opennav.org" class="hover:text-nav2-blue transition-colors">
            info@opennav.org
          </a>
        </div>
      </div>

      <!-- Link Columns -->
      {footerLinks.map((column) => (
        <div>
          <h3 class="font-semibold mb-4">{column.title}</h3>
          <ul class="space-y-2">
            {column.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-gray-300 hover:text-nav2-blue transition-colors text-sm"
                  target={link.external ? '_blank' : undefined}
                  rel={link.external ? 'noopener noreferrer' : undefined}
                >
                  {link.label}
                  {link.external && (
                    <svg class="inline-block w-3 h-3 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                    </svg>
                  )}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom -->
    <div class="mt-12 pt-8 border-t border-gray-600 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-gray-400 text-sm">
        &copy; {currentYear} Open Navigation LLC. All rights reserved.
      </p>
      <p class="text-gray-400 text-sm">
        Nav2 is a trademark of Open Navigation LLC. ROS is a trademark of Open Robotics.
      </p>
    </div>
  </div>
</footer>

