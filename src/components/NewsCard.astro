---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  author: string;
  slug: string;
  tags?: string[];
}

const { title, description, pubDate, author, slug, tags = [] } = Astro.props;
const base = import.meta.env.BASE_URL;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="glass-card glass-card-hover rounded-xl overflow-hidden group">
  <a href={`${base}news/${slug}`} class="block p-6">
    <div class="flex flex-wrap gap-2 mb-3">
      {tags.slice(0, 2).map((tag) => (
        <span class="px-2 py-1 bg-nav2-blue/10 text-nav2-blue dark:text-nav2-blue-light text-xs font-medium rounded">
          {tag}
        </span>
      ))}
    </div>

    <h3 class="text-xl font-semibold text-nav2-grey dark:text-white mb-2 group-hover:text-nav2-blue transition-colors">
      {title}
    </h3>

    <p class="text-gray-600 dark:text-gray-300 mb-4 line-clamp-2">
      {description}
    </p>

    <div class="flex items-center justify-between text-sm text-gray-500 dark:text-gray-400">
      <span>{author}</span>
      <time datetime={pubDate.toISOString()}>{formattedDate}</time>
    </div>
  </a>
</article>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
